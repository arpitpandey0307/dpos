# DPOS — Daily Performance Operating System
# Copy this file to .env and fill in your values

# PostgreSQL connection string (pooled — used by Prisma Client at runtime)
# Get this from Supabase / Neon dashboard
DATABASE_URL="postgresql://user:password@host:5432/dpos?sslmode=require&pgbouncer=true"

# Direct connection (non-pooled — used by Prisma Migrate)
DIRECT_URL="postgresql://user:password@host:5432/dpos?sslmode=require"

# JWT secret — MUST be a strong random string in production
# Generate one: openssl rand -base64 64
JWT_SECRET=""

# JWT expiry
JWT_EXPIRES_IN="7d"

# App URL (set to your Vercel domain in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
